{
  "name": "secureci",
  "version": "1.0.0",
  "description": "CLI security scanner for Pull Requests",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "secureci": "./dist/index.js",
    "secure-ci": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest",
    "test:e2e": "vitest run tests/e2e"
  },
  "keywords": ["security", "scanner", "ci", "sast"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "ora": "^8.0.1",
    "execa": "^8.0.1",
    "simple-git": "^3.22.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "@octokit/rest": "^20.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.3.3",
    "tsup": "^8.0.1",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
